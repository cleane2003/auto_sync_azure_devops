# ============================================================
# Azure DevOps Auto Sync - Configuração
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com credenciais reais!
# ============================================================

# --- Azure DevOps ---
AZURE_ORG=mosten-core               # Nome da organização
AZURE_PROJECT=ALO001-26             # Nome do projeto
AZURE_PAT=SEU_TOKEN_AQUI            # Personal Access Token (Scopes: Work Items - Read)
AZURE_EMAIL=SEU_EMAIL@mosten.com    # Email da conta Azure DevOps

# --- Saída ---
DOCS_FOLDER=C:\Projects\deliflow-monorepo\docs  # Pasta raiz de destino dos specs

# --- Execução ---
COLUMN_NAME=Agent Ready    # Coluna do board de User Story
FEATURE_COLUMN=In Progress # Coluna do board de Feature
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
AZURE_VERBOSE_CONFIG=0     # 1 = exibe config ao iniciar, 0 = silencioso
